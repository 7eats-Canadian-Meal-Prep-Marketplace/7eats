# Neon Postgres connection string (required)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret for signing short-lived HTTP-only cookies (e.g. application_submitted)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=your-random-32-byte-hex-secret

# Secret key for internal admin endpoints (issue-link, reissue-link)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=your-random-32-byte-hex-secret

# Rate limiting — both are optional; defaults shown
RATE_LIMIT_WINDOW_MINUTES=60
RATE_LIMIT_MAX_ATTEMPTS=3

# Cloudflare R2 object storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_PUBLIC_BUCKET_URL_LISTINGS=https://your-listings-cdn-domain.com
R2_PUBLIC_BUCKET_URL_AVATARS=https://your-avatars-cdn-domain.com
