# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── App ──────────────────────────────────────────────────────────────────────
# Base URL — used by Better Auth (baseURL) and for building magic links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Signs short-lived HTTP-only cookies (application_submitted, pending_phone)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=

# Protects /api/internal/issue-link and /api/internal/reissue-link
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=
# Required in production: comma-separated IPs allowed to call internal routes
# (e.g. your office IP or Vercel WAF egress). Requests must still send x-internal-key.
INTERNAL_API_ALLOWLIST=

# Protects /api/cron/reconcile. Vercel Cron auto-sends this as
# "Authorization: Bearer <CRON_SECRET>" when the env var is set in the project.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Rate limiting (optional — defaults shown)
RATE_LIMIT_WINDOW_MINUTES=60
RATE_LIMIT_MAX_ATTEMPTS=3

# ── Better Auth ──────────────────────────────────────────────────────────────
# Signs sessions — generate same way as COOKIE_SECRET
BETTER_AUTH_SECRET=

# ── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# From mailbox (display name is set in code: noreply vs 7eats Team)
RESEND_FROM_EMAIL=noreply@7eats.ca
RESEND_TEAM_EMAIL=ops@7eats.ca

# ── Twilio Verify (phone OTP) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=VA...
# E.164 sender for order/status texts (e.g. +14165550100)
TWILIO_MESSAGING_FROM_NUMBER=

# ── Stripe Connect ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...         # platform webhook (invoices, subscriptions, charges)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_... # connect webhook (payouts, account.updated)

# ── Sales tax (GST/HST) ──────────────────────────────────────────────────────
# Master switch for collecting Canadian sales tax. OFF until 7eats is registered
# for a GST/HST number (you must not collect tax you cannot remit). Flip to
# "true" once registered. Default when unset: OFF.
NEXT_PUBLIC_TAX_COLLECTION_ENABLED=false

# Protects GET /api/cron/reconcile (scheduled payment reconciliation job)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── Mapbox (delivery distance + address search) ───────────────────────────────
# Required in production when delivery is enabled (also in lib/env.ts CRITICAL list)
MAPBOX_SECRET_TOKEN=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET_URL_LISTINGS=https://...
R2_PUBLIC_BUCKET_URL_AVATARS=https://...
